{
  "name": "gdt-interface-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "TypeScript parser/writer for German GDT medical exchange files (Gerätedatenträger)",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.lib.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "demo:dev": "npm run build && concurrently \"tsc -p tsconfig.lib.json --watch\" \"npm --prefix demo run dev\" \"tsx watch demo/server.ts\"",
    "demo:build": "npm run build && npm --prefix demo run build",
    "demo:preview": "npm --prefix demo run preview -- --port 4173"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.1"
  },
  "engines": {
    "node": ">=20"
  }
}
